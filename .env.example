# ------------------------------------------------------------------------------
# Shared environment template for the monorepo
# Copy values into:
# - frontend/.env.local
# - studio/.env.local
# ------------------------------------------------------------------------------

# ----------------------------
# Frontend (Next.js) variables
# ----------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID="<paste your project ID here>" # Required
NEXT_PUBLIC_SANITY_DATASET="production" # Required
NEXT_PUBLIC_SANITY_API_VERSION="2025-09-25" # Optional
NEXT_PUBLIC_SANITY_STUDIO_URL="http://localhost:3333" # Optional
SANITY_API_READ_TOKEN="<paste your read token here>" # Required
SANITY_API_WRITE_TOKEN="<paste your write token here>" # Required

# ----------------------------
# Studio (Sanity) variables
# ----------------------------
SANITY_STUDIO_PROJECT_ID="<paste your project ID here>" # Required
SANITY_STUDIO_DATASET="production" # Required
SANITY_STUDIO_PREVIEW_URL="http://localhost:3000" # Optional
SANITY_STUDIO_STUDIO_HOST="" # Optional (used for hosted Studio)
